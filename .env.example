# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# These feed config.py, which every script imports its secrets from.

# PriceYak account + API key (https://www.priceyak.com -> account settings)
PY_ACCOUNT_ID=your_priceyak_account_id
PY_API_KEY=your_priceyak_api_key

# OpenAI (used for AI title/description generation). Often already exported in
# your shell as OPENAI_API_KEY; set here only if you prefer the .env.
OPENAI_API_KEY=sk-your_openai_key

# eBay developer app Cert ID (Production). Per-call auth tokens live in
# credentials.txt (see credentials.example.txt), not here.
EBAY_CERT_ID=PRD-your_ebay_cert_id
